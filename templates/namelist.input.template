&physics
!=========================================================================
! Physics options optimized for Fire Weather Index (FWI) calculations
! Key output variables: T2, Q2 (->RH), U10, V10, RAINNC, RAINC
!=========================================================================
 
 ! Microphysics: Thompson (8) - good precipitation forecasts
 mp_physics                          = {{MP_PHYSICS}},    {{MP_PHYSICS}},    {{MP_PHYSICS}},
 
 ! Cumulus: Kain-Fritsch for coarse domains, explicit for d03
 cu_physics                          = {{CU_PHYSICS_D01}}, {{CU_PHYSICS_D02}}, {{CU_PHYSICS_D03}},
 
 ! Radiation: RRTMG (4) - accurate for surface energy balance
 ra_lw_physics                       = {{RA_LW_PHYSICS}}, {{RA_LW_PHYSICS}}, {{RA_LW_PHYSICS}},
 ra_sw_physics                       = {{RA_SW_PHYSICS}}, {{RA_SW_PHYSICS}}, {{RA_SW_PHYSICS}},
 radt                                = {{RADT}},          {{RADT}},          {{RADT}},
 
 ! PBL: YSU (1) - reliable for temperature and wind profiles
 bl_pbl_physics                      = {{BL_PBL_PHYSICS}}, {{BL_PBL_PHYSICS}}, {{BL_PBL_PHYSICS}},
 bldt                                = 0,     0,     0,
 
 ! Surface Layer: MM5 Monin-Obukhov (1)
 sf_sfclay_physics                   = {{SF_SFCLAY_PHYSICS}}, {{SF_SFCLAY_PHYSICS}}, {{SF_SFCLAY_PHYSICS}},
 
 ! Land Surface: Noah-MP (4) - best for fire weather variables
 ! Provides accurate soil moisture, surface temperature, humidity
 sf_surface_physics                  = {{SF_SURFACE_PHYSICS}}, {{SF_SURFACE_PHYSICS}}, {{SF_SURFACE_PHYSICS}},
 num_land_cat                        = {{NUM_LAND_CAT}},
 num_soil_layers                     = {{NUM_SOIL_LAYERS}},
 
 ! Additional options
 icloud                              = 1,
 sf_urban_physics                    = 0,     0,     0,
 
 ! SST update (if running > 24h with varying SST)
 sst_update                          = 0,
/

