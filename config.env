#!/bin/bash
# =============================================================================
# WRF-FWI Portugal Configuration File
# =============================================================================
# This file contains all user-configurable settings for the WRF simulation.
# Edit this file to match your system and desired simulation period.
# =============================================================================

# -----------------------------------------------------------------------------
# SYSTEM PATHS (REQUIRED - Adjust to your installation)
# -----------------------------------------------------------------------------

# Path to WRF installation directory (containing run/, main/, etc.)
export WRF_DIR="${HOME}/WRF/WRF-4.7.1"

# Path to WPS installation directory (containing geogrid/, ungrib/, metgrid/)
export WPS_DIR="${HOME}/WRF/WPS-4.6.0"

# Path to WPS geographical data (static terrain, landuse, etc.)
export GEOG_DATA_PATH="${HOME}/WRF/GEOG/WPS_GEOG"

# Path to MPICH installation (for parallel execution)
export MPICH_DIR="${HOME}/WRF/Libs/MPICH"

# Path to NetCDF installation (C and Fortran)
export NETCDF="${HOME}/WRF/Libs/NETCDF"

# Path to this project's root directory (auto-detected)
export PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Add MPICH to PATH (required for mpirun)
export PATH="${MPICH_DIR}/bin:$PATH"

# Add shared libraries to LD_LIBRARY_PATH (required for WPS/WRF executables)
export LD_LIBRARY_PATH="${NETCDF}/lib:${MPICH_DIR}/lib:${HOME}/WRF/Libs/grib2/lib:${LD_LIBRARY_PATH}"

# -----------------------------------------------------------------------------
# SIMULATION PERIOD (REQUIRED)
# -----------------------------------------------------------------------------
# You can define the simulation period in two ways:
#   1. Explicit dates: Set both START_DATE and END_DATE
#   2. Forecast mode: Set START_DATE and FORECAST_DURATION_HOURS
#
# If FORECAST_DURATION_HOURS is set, END_DATE will be calculated automatically.
# If both END_DATE and FORECAST_DURATION_HOURS are set, FORECAST_DURATION_HOURS
# takes precedence.
# -----------------------------------------------------------------------------

# Start date/time (UTC) - Format: YYYY-MM-DD_HH:MM:SS
export START_DATE="2026-03-18_24:00:00"

# End date/time (UTC) - Format: YYYY-MM-DD_HH:MM:SS
# Optional if FORECAST_DURATION_HOURS is set
# (e.g.) export END_DATE="2025-12-03_00:00:00"

# Forecast duration in hours (alternative to END_DATE)
# Examples: 24 (1-day), 48 (2-day), 72 (3-day), 120 (5-day)
# If set, END_DATE will be calculated as START_DATE + FORECAST_DURATION_HOURS
 export FORECAST_DURATION_HOURS=24

# GFS data interval in seconds (10800 = 3 hours)
export INTERVAL_SECONDS=10800

# -----------------------------------------------------------------------------
# DOMAIN CONFIGURATION (Portugal Triple-Nest)
# -----------------------------------------------------------------------------
# The default configuration uses a triple-nested domain:
#   d01: 25km - Synoptic (Europe/Atlantic)
#   d02: ~8.3km - Regional (Iberian Peninsula)  
#   d03: ~2.8km - Local (Portugal high-resolution)
#
# Nesting ratio: 3:1 at each level (25 -> ~8.3 -> ~2.8)
#
# TO DISABLE A DOMAIN:
#   - Set MAX_DOM to the number of domains you want (1, 2, or 3)
#   - Example: MAX_DOM=2 will run only d01 (25km) and d02 (~8.3km)
#   - Example: MAX_DOM=1 will run only d01 (25km)
#   - The d03 (~2.8km) domain is computationally expensive, disable it for longer forecasts
# -----------------------------------------------------------------------------

# Number of domains to run (1, 2, or 3)
# Set to 2 to disable the ~2.8km domain, set to 1 for only the 25km domain
export MAX_DOM=2

# Parent domain (d01) - Synoptic scale
export D01_DX=25000              # Grid spacing in meters
export D01_DY=25000              # Grid spacing in meters
export D01_E_WE=120              # Grid points in west-east direction
export D01_E_SN=100              # Grid points in south-north direction

# Child domain (d02) - Regional scale (sufficient for Iberian Peninsula)
export D02_PARENT_GRID_RATIO=3  # 25km / 3 = ~8.3km
export D02_I_PARENT_START=35    # Starting i-index in parent domain
export D02_J_PARENT_START=25    # Starting j-index in parent domain
export D02_E_WE=151              # Must satisfy: (e_we - 1) % parent_ratio = 0
export D02_E_SN=181

# Grandchild domain (d03) - Local high-resolution
# NOTE: This domain is computationally expensive. Set MAX_DOM=2 above to disable it.
# Recommended: Use d03 only for short forecasts (24-48h)
export D03_PARENT_GRID_RATIO=3  # ~8.3km / 3 = ~2.8km
export D03_I_PARENT_START=40    # Starting i-index in d02
export D03_J_PARENT_START=35    # Starting j-index in d02
export D03_E_WE=202              # Must satisfy: (e_we - 1) % parent_ratio = 0
export D03_E_SN=301

# -----------------------------------------------------------------------------
# MAP PROJECTION (Lambert Conformal for mid-latitudes)
# -----------------------------------------------------------------------------

export MAP_PROJ="lambert"
export REF_LAT=39.5             # Domain center latitude (Portugal)
export REF_LON=-8.0             # Domain center longitude
export TRUELAT1=35.0            # First true latitude
export TRUELAT2=45.0            # Second true latitude
export STAND_LON=-8.0           # Standard longitude (usually = ref_lon)

# -----------------------------------------------------------------------------
# VERTICAL LEVELS
# -----------------------------------------------------------------------------

export E_VERT=45                # Number of vertical levels (recommended for p_top=5000Pa)
export P_TOP=5000               # Pressure at model top (Pa)
export NUM_METGRID_LEVELS=34    # Levels in input data (GFS = 34)
export NUM_METGRID_SOIL_LEVELS=4 # Soil levels in input data (GFS = 4)

# -----------------------------------------------------------------------------
# TIME STEPPING
# -----------------------------------------------------------------------------
# Rule of thumb: time_step (seconds) ≈ 6 × dx (km) for stability
# d01: 25km -> ~150s (use 150)
# d02: ~8.3km -> ~50s  (parent_time_step_ratio = 3)
# d03: ~2.8km -> ~17s  (parent_time_step_ratio = 3)

export TIME_STEP=150            # Time step for d01 in seconds

# -----------------------------------------------------------------------------
# OUTPUT SETTINGS
# -----------------------------------------------------------------------------

export HISTORY_INTERVAL=60      # Output interval in minutes (60 = hourly)
export FRAMES_PER_OUTFILE=24    # Frames per output file (24 = 1 day per file with hourly output)
export RESTART_INTERVAL=1440    # Restart file interval in minutes (1440 = daily)

# -----------------------------------------------------------------------------
# PHYSICS OPTIONS (Optimized for FWI/Fire Weather)
# -----------------------------------------------------------------------------
# These are tuned for mid-latitude land surface processes

export MP_PHYSICS=8             # Thompson microphysics (good for precip)
export RA_LW_PHYSICS=4          # RRTMG longwave
export RA_SW_PHYSICS=4          # RRTMG shortwave
export RADT=15                  # Radiation call frequency (minutes)
export SF_SFCLAY_PHYSICS=5      # MYNN surface layer
export SF_SURFACE_PHYSICS=4     # Noah-MP land surface (best for fire weather)
export BL_PBL_PHYSICS=5         # MYNN 2.5-level (better for coastal/stable conditions)
export CU_PHYSICS_D01=16        # New Tiedtke (better for European/Mediterranean climate)
export CU_PHYSICS_D02=0         # Off (grey zone at ~8.3km, avoid double-counting)
export CU_PHYSICS_D03=0         # No cumulus for d03 (resolved at ~2.8km)
export NUM_LAND_CAT=21          # MODIS land use categories
export NUM_SOIL_LAYERS=4        # Noah-MP soil layers

# -----------------------------------------------------------------------------
# PARALLEL EXECUTION
# -----------------------------------------------------------------------------

export NUM_PROCESSORS=8        # Number of cores for parallel execution
export USE_MPI=true             # Use MPI for parallel execution

# Tile decomposition: NUM_TILES_Y × NUM_TILES_X = NUM_PROCESSORS
export NUM_TILES_X=4            # Tiles in X direction
export NUM_TILES_Y=2            # Tiles in Y direction

# Performance tuning
export NUMTILES=1               # Tiles per patch (1 optimal)


# -----------------------------------------------------------------------------
# DATA PATHS
# -----------------------------------------------------------------------------

export GFS_DATA_DIR="${PROJECT_DIR}/GFS_DATA"
export WORKSPACE_DIR="${PROJECT_DIR}/workspace"
export OUTPUT_DIR="${PROJECT_DIR}/workspace/output"


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

export LOG_LEVEL="INFO"         # DEBUG, INFO, WARNING, ERROR
export LOG_FILE="${PROJECT_DIR}/workspace/logs/wrf_forecast.log"

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
